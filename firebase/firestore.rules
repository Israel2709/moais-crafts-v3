rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // v1: no client writes. Admin SDK bypasses rules.
    // Future: auth + moaisCatalog_admins/{uid}
    match /moaisCatalog_designs/{designId} {
      // Designs are personal inventory; public access goes through API
      // after checking sales-catalog membership.
      allow read, write: if false;
    }

    match /moaisCatalog_salesCatalogs/{catalogId} {
      allow read: if resource.data.status == 'published';
      allow write: if false;
    }

    match /moaisCatalog_taxonomies/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /moaisCatalog_admins/{uid} {
      allow read, write: if false;
    }

    match /moaisCatalog_driveSources/{sourceId} {
      allow read, write: if false;
    }
  }
}
