# Firebase client (raziel-app-hub)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=raziel-app-hub.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://raziel-app-hub-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=raziel-app-hub
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=raziel-app-hub.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin — prefer a local file under .data/ (gitignored)
FIREBASE_SERVICE_ACCOUNT_PATH=.data/firebase-service-account.json
# Or paste the full service account JSON as a single line:
FIREBASE_SERVICE_ACCOUNT_JSON=

# Super admin emails (comma-separated). Only these can access admin UI + APIs.
MOAIS_SUPER_ADMIN_EMAILS=israel.salinas.m@gmail.com

# Seller emails (comma-separated). These log in and go straight to /p/catalog.
MOAIS_SELLER_EMAILS=

# Google Drive OAuth (Desktop/Web client) — separate from Firebase Auth login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3040/api/drive/callback
# Filled after first OAuth success (or use .data/drive-token.json)
GOOGLE_DRIVE_REFRESH_TOKEN=

# Optional: root folder ID of the shared community Drive folder
GOOGLE_DRIVE_ROOT_FOLDER_ID=
